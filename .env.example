NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_WOOCOMMERCE_URL=

WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

PAYMENT_ENABLED_PROVIDERS=gpay_qr,onepay_card,cash_agent

# -------------------------------------------------------------------
# GPay
# -------------------------------------------------------------------

GPAY_ENV=sandbox

# API kết nối QR Payment của GPay
GPAY_QR_BASE_URL=

# Thông tin xác thực do GPay cấp
GPAY_QR_MERCHANT_CODE=
GPAY_QR_PASSWORD=
GPAY_QR_STORE_CODE=
GPAY_QR_TERMINAL_ID=
GPAY_QR_ACCOUNT_NAME=YSIM
GPAY_QR_SOURCE_OF_FUND=VIETQR

# Khóa riêng của YSim dùng để ký request.
# File phải là PEM private key và không được commit vào Git.
GPAY_PRIVATE_KEY_PATH=

# X.509 certificate của YSim:
# -----BEGIN CERTIFICATE-----
# Certificate này được khai báo trên GPay Developer Portal.
GPAY_CERTIFICATE_PATH=

# Certificate/public certificate do GPay cung cấp,
# dùng để xác minh response hoặc webhook từ GPay.
GPAY_VERIFY_CERTIFICATE_PATH=

# URL callback/webhook công khai
GPAY_QR_WEBHOOK_URL=
GPAY_QR_RETURN_URL=

# -------------------------------------------------------------------
# OnePay
# -------------------------------------------------------------------

ONEPAY_ENV=sandbox
ONEPAY_PAYMENT_URL=
ONEPAY_QUERY_URL=
ONEPAY_MERCHANT_ID=
ONEPAY_ACCESS_CODE=
ONEPAY_SECURE_SECRET=
ONEPAY_RETURN_URL=
ONEPAY_IPN_URL=

# -------------------------------------------------------------------
# Cash / Agent
# -------------------------------------------------------------------

CASH_PAYMENT_ENABLED=true