# Gigago fulfillment - local development only
GIGAGO_ENV=sandbox
GIGAGO_BASE_URL=https://sandbox-partners-api.gigago.com
GIGAGO_API_KEY=
GIGAGO_TIMEOUT_MS=15000

# Protects all /api/fulfillment/gigago/test-* routes.
# Generate a random value with at least 32 bytes.
GIGAGO_TEST_SECRET=

# Required by createPartnerOrder.
# Use the future public sandbox callback URL while local F02 relies on polling.
GIGAGO_WEBHOOK_URL=https://sandbox.ysim.vn/api/fulfillment/gigago/webhook

# F02 safe defaults.
GIGAGO_F02_DEMO_PLAN_ID=GIGA-DEMO
GIGAGO_FULFILLMENT_ALLOWED_ORDER_STATUSES=processing,completed

# Sandbox verified POST on 2026-07-24.
# Production must be probed before activation.
GIGAGO_GET_MY_ORDERS_METHOD=