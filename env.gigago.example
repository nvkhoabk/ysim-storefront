# Gigago fulfillment - local development only
GIGAGO_ENV=sandbox
GIGAGO_BASE_URL=https://sandbox-partners-api.gigago.com
GIGAGO_API_KEY=
GIGAGO_TIMEOUT_MS=15000

# Protects /api/fulfillment/gigago/test-connectivity
# Generate a random value with at least 32 bytes.
GIGAGO_TEST_SECRET=

# Required later by createPartnerOrder.
# localhost is not a valid webhook destination for Gigago.
GIGAGO_WEBHOOK_URL=
