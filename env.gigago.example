# Gigago fulfillment
GIGAGO_ENV=sandbox
GIGAGO_BASE_URL=https://sandbox-partners-api.gigago.com
GIGAGO_API_KEY=
GIGAGO_TIMEOUT_MS=15000

# Protects all /api/fulfillment/gigago/test-* routes.
GIGAGO_TEST_SECRET=

# Gigago webhook credential.
GIGAGO_WEBHOOK_TOKEN=
GIGAGO_WEBHOOK_MAX_BODY_BYTES=262144
GIGAGO_WEBHOOK_URL=https://sandbox.ysim.vn/api/fulfillment/gigago/webhook?token=

# F02/F04 safe defaults.
GIGAGO_F02_DEMO_PLAN_ID=GIGA-DEMO
GIGAGO_FULFILLMENT_ALLOWED_ORDER_STATUSES=processing,completed

# Sandbox verified POST on 2026-07-24.
# Production must be probed before activation.
GIGAGO_GET_MY_ORDERS_METHOD=

# GPay -> WooCommerce -> Gigago orchestration.
# Roll out in order: disabled -> record -> fulfill.
GPAY_COMMERCE_AUTOMATION_MODE=disabled

# Keep true. Automatic commerce changes require callback SUCCESS and
# query reconciliation SUCCESS.
GPAY_COMMERCE_AUTOMATION_REQUIRE_QUERY=true
GPAY_CALLBACK_RECONCILIATION_MODE=query

# auto-draft, trash, cancelled, refunded and failed are blocked.
GPAY_COMMERCE_ALLOWED_ORDER_STATUSES=pending,on-hold,processing,completed
